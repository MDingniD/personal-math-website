---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a class="card-link" href={href}>
  <article class="card">
    <h3>{title}</h3>
    <p>{description}</p>
  </article>
</a>

<style>
  .card-link {
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
  }

  h3 {
    margin-top: 0;
    margin-bottom: 0.6rem;
    color: #1f1f1f;
  }

  p {
    margin: 0;
    color: #5f5f5f;
  }
</style>