---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeCard from "../components/HomeCard.astro";
---

<BaseLayout title="Yiding Ma">
  <section class="page-title hero">
  <div class="hero-text">
    <h1>Yiding Ma</h1>
    <p class="subtitle">
      Mathematics undergraduate at the University of Edinburgh, interested in
      representation theory, and algebraic geometry.
    </p>
  <a 
    href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/CV_Yiding.pdf`} 
    class="cv-link" 
    target="_blank"
  >
    View CV <span aria-hidden="true">→</span>
  </a>
  </div>

  <img 
  src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/profile.jpg`} 
  alt="Yiding Ma" 
  class="hero-img" 
  />
</section>

  <section>
    <h2>About</h2>
    <p>
      This website is a long-term collection of my mathematical notes, course pages,
      reading records, and related writing. I am especially interested in algebra,
      representation theory, and geometry.
    </p>
  </section>

  <section>
    <h2>Current interests</h2>
    <p class="muted">
      Algebra · Representation theory · Algebraic geometry
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero-text {
    flex: 1;
    min-width: 260px;
  }

  .hero-img {
	width: clamp(120px, 18vw, 170px);
  	height: clamp(120px, 18vw, 170px);
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid #ddd8cf;
  }

  .links {
    margin-top: 1.25rem;
  }

  .cv-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    font-weight: 500;
    color: var(--text-color, #333); /* Uses your site's text color */
    border-bottom: 1px solid #ddd8cf;
    padding-bottom: 2px;
    transition: border-color 0.2s ease;
  }

  .cv-link:hover {
    border-color: #444;
  }

  .cv-link span {
    margin-left: 0.4rem;
  }
</style>

